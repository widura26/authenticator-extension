{
  "manifest_version": 3,
  "name": "Simple 2FA Authenticator",
  "version": "1.0",
  "description": "A simple browser extension to generate 2FA codes.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}